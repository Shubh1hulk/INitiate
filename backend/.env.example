# Environment file for backend
# Copy this to .env and fill in your values

# ===== DATABASE =====
MONGODB_URI=mongodb://localhost:27017/lifetwin

# ===== JWT SECRET =====
# Generate a strong random string for production
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# ===== AI API KEYS =====
GROQ_API_KEY=gsk_place_your_groq_api_key_here
# Optional: for using OpenAI instead
OPENAI_API_KEY=sk_optional_openai_key

# ===== SERVER CONFIG =====
PORT=5000
NODE_ENV=development

# ===== FRONTEND URL (for CORS) =====
FRONTEND_URL=http://localhost:3000

# ===== PRODUCTION EXAMPLES =====
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lifetwin
# NODE_ENV=production
# PLfrontendRONTEND_URL=https://yourdomain.com
